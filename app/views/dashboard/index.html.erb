<turbo-frame id="dashboard-frame">
  <div class="min-h-screen bg-gray-900 text-white p-6">
    <!-- Header with Symbol Selector -->
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-white">Aegis Trading Dashboard</h1>
      <div data-controller="symbol-selector">
        <select
          id="symbol-select"
          name="symbol"
          data-action="change->symbol-selector#change"
          class="bg-gray-800 border border-gray-700 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-48 p-2"
        >
          <% %w[BTCUSDT ETHUSDT SOLUSDT BNBUSDT XRPUSDT ADAUSDT DOGEUSDT].each do |sym| %>
            <option value="<%= sym %>" <%= "selected" if @symbol == sym %>><%= sym %></option>
          <% end %>
        </select>
      </div>
    </div>

    <!-- Real-time Stream Indicator -->
    <div class="flex items-center gap-2 mb-6">
      <span class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
      </span>
      <span class="text-sm text-gray-400">Live &mdash; <%= @symbol %></span>
    </div>

    <!-- Turbo Stream Subscriptions -->
    <%= turbo_stream_from "trading:#{@symbol}" %>

    <!-- 4-Card Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Price Card -->
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Price</h2>
        <%= render "price", tick: @latest_tick %>
      </div>

      <!-- Supertrend Card -->
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Supertrend</h2>
        <%= render "supertrend", supertrend: @supertrend %>
      </div>

      <!-- Positions Card -->
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 md:col-span-2">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Positions</h2>
        <%= render "positions", positions: @positions %>
      </div>

      <!-- Account Card -->
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 md:col-span-2">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Account</h2>
        <%= render "account", account: @account %>
      </div>
    </div>
  </div>
</turbo-frame>