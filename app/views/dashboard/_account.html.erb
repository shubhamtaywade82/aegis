<turbo-frame id="account-card">
  <div id="account-card">
    <%
      # Handle both Hash and OpenStruct-like account objects
      if account.is_a?(Hash)
        balance = account["cash_balance"].to_f
        equity = account["equity"].to_f
        unrealized = account["unrealized_pnl"].to_f
        used_margin = account["used_margin"].to_f
        available = account["available_margin"].to_f
        leverage = account["leverage"].to_i
      else
        balance = account.cash_balance.to_f
        equity = account.equity.to_f
        unrealized = account.unrealized_pnl.to_f
        used_margin = account.used_margin.to_f
        available = account.available_margin.to_f
        leverage = account.leverage.to_i
      end

      pnl_color = unrealized >= 0 ? "text-green-400" : "text-red-400"
      pnl_prefix = unrealized >= 0 ? "+" : ""
    %>

    <!-- Balance & Equity Row -->
    <div class="grid grid-cols-2 gap-6 mb-6">
      <div>
        <span class="text-gray-500 text-sm block mb-1">Cash Balance</span>
        <span class="text-2xl font-bold text-white"><%= number_to_currency(balance, precision: 2) %></span>
      </div>
      <div>
        <span class="text-gray-500 text-sm block mb-1">Equity</span>
        <span class="text-2xl font-bold text-white"><%= number_to_currency(equity, precision: 2) %></span>
      </div>
    </div>

    <!-- Margin Row -->
    <div class="grid grid-cols-3 gap-4 mb-6 pt-4 border-t border-gray-700">
      <div>
        <span class="text-gray-500 text-xs block">Used Margin</span>
        <span class="text-white font-semibold"><%= number_to_currency(used_margin, precision: 2) %></span>
      </div>
      <div>
        <span class="text-gray-500 text-xs block">Available</span>
        <span class="text-white font-semibold"><%= number_to_currency(available, precision: 2) %></span>
      </div>
      <div>
        <span class="text-gray-500 text-xs block">Leverage</span>
        <span class="text-white font-semibold"><%= leverage %>x</span>
      </div>
    </div>

    <!-- Unrealized PnL -->
    <div class="pt-4 border-t border-gray-700">
      <div class="flex items-center justify-between">
        <span class="text-gray-500 text-sm">Unrealized PnL</span>
        <span class="text-xl font-bold <%= pnl_color %>">
          <%= pnl_prefix %><%= number_to_currency(unrealized, precision: 2) %>
        </span>
      </div>
    </div>
  </div>
</turbo-frame>