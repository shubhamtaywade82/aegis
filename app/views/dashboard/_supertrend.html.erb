<turbo-frame id="supertrend-card-<%= @symbol %>">
  <div id="supertrend-card-<%= @symbol %>">
    <% if supertrend %>
      <%
        direction = supertrend[:direction]
        is_bullish = direction.to_s.upcase == "BULLISH"
        badge_color = is_bullish ? "bg-green-900/30 text-green-400 border-green-700" : "bg-red-900/30 text-red-400 border-red-700"
        value_color = is_bullish ? "text-green-400" : "text-red-400"
      %>
      <!-- Direction Badge -->
      <div class="flex items-center gap-3 mb-4">
        <span class="<%= badge_color %> text-xs font-bold px-3 py-1 rounded border">
          <%= direction.to_s.upcase %>
        </span>
        <span class="text-gray-400 text-sm">Supertrend</span>
      </div>

      <!-- Value -->
      <div class="mb-4">
        <span class="text-gray-500 text-sm block">Value</span>
        <span class="<%= value_color %> text-3xl font-bold">
          <%= number_to_currency(supertrend[:value].to_f, precision: 4) %>
        </span>
      </div>

      <!-- Bands -->
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <span class="text-gray-500 block">Upper Band</span>
          <span class="text-white font-medium">
            <%= number_to_currency(supertrend[:upper_band].to_f, precision: 4) %>
          </span>
        </div>
        <div>
          <span class="text-gray-500 block">Lower Band</span>
          <span class="text-white font-medium">
            <%= number_to_currency(supertrend[:lower_band].to_f, precision: 4) %>
          </span>
        </div>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-700 mb-3">
          <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <p class="text-gray-500 text-sm">Supertrend data unavailable</p>
        <p class="text-gray-600 text-xs mt-1">Calculated on next candle close</p>
      </div>
    <% end %>
  </div>
</turbo-frame>