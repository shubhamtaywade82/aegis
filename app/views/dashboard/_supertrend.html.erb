<turbo-frame id="supertrend-card-<%= symbol %>">
  <div id="supertrend-card-<%= symbol %>" class="flex flex-col gap-4">
    <% if supertrend %>
      <%
        direction = supertrend[:direction]
        is_bullish = direction.to_s.upcase == "BULLISH"
        badge_color = is_bullish ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/20" : "bg-rose-500/10 text-rose-400 border-rose-500/20"
        value_color = is_bullish ? "text-emerald-400" : "text-rose-400"
        neon_text_class = is_bullish ? "neon-text-green" : "neon-text-red"
      %>
      <!-- Direction Badge & Label Row -->
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-2.5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full <%= is_bullish ? "bg-emerald-400" : "bg-rose-400" %> opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 <%= is_bullish ? "bg-emerald-400" : "bg-rose-400" %>"></span>
          </span>
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider">Supertrend Direction</span>
        </div>

        <span class="<%= badge_color %> text-xs font-black px-3 py-1.5 rounded-xl border tracking-widest uppercase">
          <%= direction.to_s.upcase %>
        </span>
      </div>

      <div class="h-px bg-white/5 w-full"></div>

      <!-- Value -->
      <div>
        <span class="text-xs text-gray-500 font-semibold block mb-1">Trigger Value</span>
        <span class="<%= value_color %> <%= neon_text_class %> text-3xl md:text-4xl font-extrabold tracking-tight">
          <%= number_to_currency(supertrend[:value].to_f, precision: 2) %>
        </span>
      </div>

      <!-- Bands -->
      <div class="grid grid-cols-2 gap-6">
        <div class="bg-white/[0.02] border border-white/5 rounded-xl p-3">
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block mb-1">Upper Band</span>
          <span class="text-white text-base font-semibold">
            <%= number_to_currency(supertrend[:upper_band].to_f, precision: 2) %>
          </span>
        </div>
        <div class="bg-white/[0.02] border border-white/5 rounded-xl p-3">
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block mb-1">Lower Band</span>
          <span class="text-white text-base font-semibold">
            <%= number_to_currency(supertrend[:lower_band].to_f, precision: 2) %>
          </span>
        </div>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center text-center py-10">
        <div class="w-12 h-12 rounded-full bg-slate-800/80 border border-white/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2"/>
          </svg>
        </div>
        <p class="text-gray-400 font-semibold">Supertrend data unavailable</p>
        <p class="text-gray-600 text-xs mt-1">Calculated on next candle close...</p>
      </div>
    <% end %>
  </div>
</turbo-frame>